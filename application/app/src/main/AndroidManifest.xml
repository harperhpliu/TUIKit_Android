<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature android:name="android.hardware.camera" />
    <uses-feature android:name="android.hardware.camera.autofocus" />

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application
        android:name="com.tencent.rtcube.v2.App"
        android:allowBackup="false"
        android:icon="@drawable/app_ic_launcher"
        android:roundIcon="@drawable/app_ic_launcher"
        android:label="@string/root_app_name"
        android:supportsRtl="true"
        tools:replace="android:allowBackup,android:theme,android:label"
        android:theme="@style/Theme.RTCubeV2">

        <provider
            android:name="com.tencent.rtcube.v2.main.common.utils.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.RTCubeV2">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".privacy.PrivacyActivity"
            android:exported="false"
            android:theme="@style/Theme.RTCubeV2" />

        <activity
            android:name=".mine.MineActivity"
            android:exported="false"
            android:theme="@style/Theme.RTCubeV2" />

    </application>

</manifest>
