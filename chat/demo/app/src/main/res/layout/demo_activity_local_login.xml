<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/demo_loginRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/demo_heroSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/demo_bg_login_hero"
        android:clipChildren="true">

        <ImageView
            android:id="@+id/demo_ivHeroWatermark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="-60dp"
            android:contentDescription="@null"
            android:src="@drawable/demo_ic_login_logo_watermark" />

        <LinearLayout
            android:id="@+id/demo_topSwitchers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:layoutDirection="locale"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/demo_themeSwitcher"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp">

                <ImageView
                    android:id="@+id/demo_ivThemeIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@string/demo_settings_theme"
                    android:src="@drawable/demo_ic_login_theme" />

                <TextView
                    android:id="@+id/demo_tvThemeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="#FFFFFFFF"
                    android:textDirection="locale"
                    android:textSize="13sp" />

                <ImageView
                    android:id="@+id/demo_ivThemeArrow"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="2dp"
                    android:src="@drawable/demo_ic_login_arrow_down" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/demo_languageSwitcher"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp">

                <ImageView
                    android:id="@+id/demo_ivLanguageIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@string/demo_settings_language"
                    android:src="@drawable/demo_ic_login_language" />

                <TextView
                    android:id="@+id/demo_tvLanguageValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="#FFFFFFFF"
                    android:textDirection="locale"
                    android:textSize="13sp" />

                <ImageView
                    android:id="@+id/demo_ivLanguageArrow"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="2dp"
                    android:src="@drawable/demo_ic_login_arrow_down" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/demo_heroContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="28dp"
            android:gravity="center_vertical"
            android:layoutDirection="locale"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/demo_ivHeroLogo"
                android:layout_width="80dp"
                android:layout_height="40dp"
                android:contentDescription="@string/demo_app_name"
                android:src="@drawable/demo_ic_login_logo" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/demo_tvHeroTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/demo_login_hero_title"
                    android:textAlignment="viewStart"
                    android:textColor="#FFFFFFFF"
                    android:textDirection="locale"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/demo_tvHeroSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/demo_login_hero_subtitle"
                    android:textAlignment="viewStart"
                    android:textColor="#CCFFFFFF"
                    android:textDirection="locale"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/demo_loginPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.6">

        <LinearLayout
            android:id="@+id/demo_loginFormContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginTop="36dp"
            android:layoutDirection="locale"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:id="@+id/demo_tvUserIdLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/demo_login_user_id_label"
                android:textAlignment="viewStart"
                android:textDirection="locale"
                android:textSize="17sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/demo_editUserID"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@null"
                android:hint="@string/demo_input_user_id_tips"
                android:imeOptions="actionDone"
                android:importantForAutofill="no"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:textAlignment="viewStart"
                android:textDirection="locale"
                android:textSize="16sp" />

            <View
                android:id="@+id/demo_editDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/demo_btnLogin"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="48dp"
                android:enabled="false"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:stateListAnimator="@null"
                android:text="@string/demo_login"
                android:textAllCaps="false"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
