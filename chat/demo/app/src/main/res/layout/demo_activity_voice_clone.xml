<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/demo_voiceCloneRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="locale"
    android:orientation="vertical">

    <include layout="@layout/demo_widget_chat_header" />

    <ScrollView
        android:id="@+id/demo_voiceCloneScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layoutDirection="locale"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/demo_tvVoiceCloneTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/demo_tvVoiceCloneReadingTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/demo_tvVoiceCloneSample"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:textSize="14sp" />

            <FrameLayout
                android:id="@+id/demo_voiceCloneWaveContainer"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="32dp" />

            <TextView
                android:id="@+id/demo_tvVoiceCloneTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:textSize="22sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/demo_voiceCloneRecordBtn"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/demo_ivVoiceCloneRecordIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/demo_ic_voice_mic" />
            </FrameLayout>

            <TextView
                android:id="@+id/demo_tvVoiceCloneStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/demo_tvVoiceCloneAuthTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:textAlignment="viewStart"
                android:textDirection="locale"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/demo_etVoiceCloneName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@null"
                android:gravity="center_vertical"
                android:inputType="text"
                android:maxLines="1"
                android:minHeight="48dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:textAlignment="viewStart"
                android:textDirection="locale"
                android:textSize="15sp" />

            <FrameLayout
                android:id="@+id/demo_btnVoiceCloneSubmit"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/demo_tvVoiceCloneSubmit"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textSize="16sp" />

                <ProgressBar
                    android:id="@+id/demo_progressVoiceCloneSubmit"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
