<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#33000000" />
            <size
                android:width="20dp"
                android:height="20dp" />
        </shape>
    </item>
    <item
        android:left="3dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="3dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFFFF" />
            <stroke
                android:width="0.5dp"
                android:color="#26000000" />
            <size
                android:width="14dp"
                android:height="14dp" />
        </shape>
    </item>
</layer-list>
