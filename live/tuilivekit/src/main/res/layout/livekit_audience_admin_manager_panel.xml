<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="190dp"
        android:orientation="vertical"
        tools:ignore="UselessParent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="24dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <io.trtc.tuikit.atomicx.widget.basicwidget.avatar.AtomicAvatar
                android:id="@+id/iv_head"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:avatarSize="m"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/user_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:textColor="@color/common_text_color_primary"
                android:textSize="16sp"
                app:layout_constraintStart_toEndOf="@id/iv_head"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/iv_head"
               />

            <TextView
                android:id="@+id/user_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="6dp"
                android:textColor="@color/common_text_color_secondary"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="@id/iv_head"
                app:layout_constraintStart_toEndOf="@id/iv_head" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/user_controller_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/layout_dismiss_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                tools:ignore="UseCompoundDrawables">

                <RelativeLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/audio_effect_settings_item_not_select_background">

                    <ImageView
                        android:id="@+id/iv_disable_message"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_centerInParent="true"
                        android:importantForAccessibility="no"
                        android:src="@drawable/livekit_ic_disable_message" />
                </RelativeLayout>

                <io.trtc.tuikit.atomicx.widget.basicwidget.label.AtomicLabel
                    android:id="@+id/tv_disable_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="6dp"
                    android:singleLine="true"
                    android:text="@string/common_disable_message"
                    android:textColor="@color/text_color_primary"
                    android:textSize="@dimen/text_size_12" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_kick_out"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical"
                tools:ignore="UseCompoundDrawables">

                <RelativeLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/audio_effect_settings_item_not_select_background">

                    <ImageView
                        android:id="@+id/iv_kick_out_room"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_centerInParent="true"
                        android:background="@drawable/livekit_ic_kick_out_room"
                        android:importantForAccessibility="no" />
                </RelativeLayout>

                <io.trtc.tuikit.atomicx.widget.basicwidget.label.AtomicLabel
                    android:id="@+id/tv_kick_out_room"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="6dp"
                    android:singleLine="true"
                    android:text="@string/common_remove"
                    android:textColor="@color/text_color_primary"
                    android:textSize="@dimen/text_size_12" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</LinearLayout>
