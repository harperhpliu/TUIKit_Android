<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="323dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/roomkit_bg_confirm_dialog"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tv_room_password_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:gravity="center"
        android:text="@string/roomkit_enter_room_password_title"
        android:textColor="@color/roomkit_color_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginStart="14dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="14dp">

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/et_room_password"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:background="@drawable/roomkit_bg_password_edit"
            android:hint="@string/roomkit_please_input_room_password"
            android:importantForAutofill="no"
            android:inputType="numberPassword"
            android:maxLength="6"
            android:typeface="normal"
            android:paddingStart="8dp"
            android:paddingEnd="32dp"
            android:singleLine="true"
            android:textColor="@color/roomkit_color_text_primary"
            android:textColorHint="@color/roomkit_color_text_grey"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/iv_clear_password"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="9dp"
            android:contentDescription="@null"
            android:src="@drawable/roomkit_ic_clear_password"
            android:visibility="gone" />

    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginTop="24dp"
        android:background="@color/roomkit_color_text_light" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_cancel_password"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackground"
            android:gravity="center"
            android:text="@string/roomkit_cancel"
            android:textAllCaps="false"
            android:textColor="@color/roomkit_color_text_secondary"
            android:textSize="16sp" />

        <View
            android:layout_width="1px"
            android:layout_height="match_parent"
            android:background="@color/roomkit_color_text_light" />

        <TextView
            android:id="@+id/tv_confirm_password"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackground"
            android:gravity="center"
            android:text="@string/roomkit_join_room"
            android:textAllCaps="false"
            android:textColor="@color/roomkit_color_primary"
            android:textSize="16sp" />

    </LinearLayout>

</LinearLayout>
